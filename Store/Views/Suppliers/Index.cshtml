@model IEnumerable<Store.Models.Product>

@{
    ViewData["Title"] = "Мои товары";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-controller="Products" asp-action="Create" class="btn btn-success">Добавить новый товар</a>
    <a asp-controller="Suppliers" asp-action="Orders" class="btn btn-primary">Посмотреть заказы</a>
</p>

@if (!Model.Any())
{
    <p>У вас пока нет товаров.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Количество</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name</td>
                    <td>@product.Price.ToString("F2") ₽</td>
                    <td>@product.Quantity</td>
                    <td>
                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Редактировать</a>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-info">Детали</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}