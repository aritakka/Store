@model IEnumerable<Store.Models.Product>
@using Store.Models
@{
    ViewData["Title"] = "Главная — Магазин";
    var categories = ViewData["Categories"] as List<Category> ?? new List<Category>();
    var search = ViewData["SearchQuery"] as string;
    var selectedCat = ViewData["CategoryId"] as int?;
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="form-inline">
                <div class="input-group">
                    <input name="search" value="@search" class="form-control" placeholder="Поиск продуктов..." />
                    <select name="categoryId" class="form-select ms-2">
                        <option value="">Все категории</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(selectedCat == cat.Id ? "selected" : null)">@cat.Name</option>
                        }
                    </select>

                    <button class="btn btn-primary ms-2" type="submit">Поиск</button>
                </div>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Корзина</a>
            <a asp-controller="Users" asp-action="Login" class="btn btn-outline-primary ms-2">Войти</a>
        </div>
    </div>

    <h3>Популярные товары</h3>

    <div class="row">
        <div class="col-lg-4 mb-4">
            @{
                var featured = Model.FirstOrDefault();
            }

            @if (featured != null)
            {
                <div class="card">
                    <img src="~/images/products/@(featured.Id).jpg" class="card-img-top" alt="@featured.Name" onerror="this.src='/images/placeholder.png'">
                        <div class="card-body">
                            <h4 class="card-title">@featured.Name</h4>
                            <p class="card-text text-muted">@featured.Category?.Name</p>
                            <p class="card-text fw-bold">@featured.Price.ToString("C")</p>
                            <p class="card-text">@featured.Description</p>
                            <div>
                                <a href="javascript:void(0)" class="btn btn-primary btn-details" data-id="@featured.Id">Посмотреть детали</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-8">
                <div class="row">
                    @foreach (var p in Model.Skip(1))
                    {
                        <div class="col-sm-6 col-md-4 col-lg-6 mb-4">
                            @{
                                await Html.RenderPartialAsync("_ProductCard", p);
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <hr />
        <div class="row">
            <div class="col-md-4">
                <h5>Доставляем качественные продукты</h5>
                <p class="text-muted">Быстрое оформление, свежие продукты, удобные способы оплаты.</p>
            </div>
            <div class="col-md-4">
                <h5>Гарантия свежести</h5>
                <p class="text-muted">Возврат в случае несовпадения качества.</p>
            </div>
            <div class="col-md-4">
                <h5>Контакты</h5>
                <p class="text-muted">Телефон: +7 (900) 000-00-00</p>
            </div>
        </div>
    </div>

    @* Fixed bottom panel: "Посмотреть детали" *@
    <div id="product-details-panel" class="bg-white border-top shadow" style="display:none; position:fixed; left:0; right:0; bottom:0; z-index:1050; max-height:60vh; overflow:auto;">
        <div class="container py-3">
            <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex">
                    <img id="panel-img" src="/images/placeholder.png" alt="" style="width:120px; height:120px; object-fit:cover; border-radius:6px; margin-right:16px;">
                    <div>
                        <h5 id="panel-name">Название</h5>
                        <div class="text-muted" id="panel-category">Категория</div>
                        <div class="fw-bold mt-2" id="panel-price">Цена</div>
                        <div class="text-muted" id="panel-supplier">Поставщик</div>
                    </div>
                </div>
                <div class="text-end">
                    <form asp-controller="Products" asp-action="DetailsJson" method="get" style="display:none;"></form>
                    <button id="panel-close" class="btn btn-sm btn-outline-secondary">Закрыть</button>
                    <button id="panel-edit-toggle" class="btn btn-sm btn-primary ms-2">Редактировать</button>
                </div>
            </div>

            <hr />

            <div id="panel-view-mode">
                <p id="panel-description" class="mt-2 text-muted"></p>
            </div>

            <form id="panel-edit-form" style="display:none;">
                <input type="hidden" id="edit-id" name="Id" />
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Название</label>
                        <input name="Name" id="edit-name" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Цена</label>
                        <input name="Price" id="edit-price" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Количество</label>
                        <input name="Quantity" id="edit-quantity" type="number" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Категория</label>
                        <select name="CategoryId" id="edit-category" class="form-select">
                            <option value="">—</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-2">
                        <label class="form-label">Поставщик (ID)</label>
                        <input name="SupplierId" id="edit-supplier" type="number" class="form-control" />
                    </div>
                    <div class="col-12 mb-2">
                        <label class="form-label">Описание</label>
                        <textarea name="Description" id="edit-description" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-2 text-end">
                    <button type="button" id="edit-cancel" class="btn btn-sm btn-outline-secondary">Отмена</button>
                    <button type="submit" class="btn btn-sm btn-success ms-2">Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <script src="~/js/site-products.js"></script>
    }
