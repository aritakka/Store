@model IEnumerable<Store.Models.Product>
@using Store.Models
@{
    ViewData["Title"] = "Главная — Магазин";
    var categories = ViewData["Categories"] as List<Category> ?? new List<Category>();
    var search = ViewData["SearchQuery"] as string;
    var selectedCat = ViewData["CategoryId"] as int?;
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="form-inline">
                <div class="input-group">
                    <input name="search" value="@search" class="form-control" placeholder="Поиск продуктов..." />
                    <select name="categoryId" class="form-select ms-2">
                        <option value="">Все категории</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(selectedCat == cat.Id ? "selected" : null)">@cat.Name</option>
                        }
                    </select>

                    <button class="btn btn-primary ms-2" type="submit">Поиск</button>
                </div>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Корзина</a>
            <a asp-controller="Users" asp-action="Login" class="btn btn-outline-primary ms-2">Войти</a>
        </div>
    </div>

    <h3>Популярные товары</h3>
    <div class="row">
        @foreach (var p in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100">
                    <img src="~/images/products/@(p.Id).jpg" class="card-img-top" alt="@p.Name" onerror="this.src='/images/placeholder.png'">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="card-text text-muted">@p.Category?.Name</p>
                        <p class="card-text fw-bold">@p.Price.ToString("C")</p>
                        <div class="mt-auto">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Подробнее</a>
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline ms-1">
                                <input type="hidden" name="productId" value="@p.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary">В корзину</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <hr />
    <div class="row">
        <div class="col-md-4">
            <h5>Доставляем качественные продукты</h5>
            <p class="text-muted">Быстрое оформление, свежие продукты, удобные способы оплаты.</p>
        </div>
        <div class="col-md-4">
            <h5>Гарантия свежести</h5>
            <p class="text-muted">Возврат в случае несовпадения качества.</p>
        </div>
        <div class="col-md-4">
            <h5>Контакты</h5>
            <p class="text-muted">Телефон: +7 (900) 000-00-00</p>
        </div>
    </div>
</div>
