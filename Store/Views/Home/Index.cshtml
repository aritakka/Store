@model IEnumerable<Store.Models.Product>
@using Store.Models
@{
    ViewData["Title"] = "Главная — Магазин";
    var categories = ViewData["Categories"] as List<Category> ?? new List<Category>();
    var search = ViewData["SearchQuery"] as string;
    var selectedCat = ViewData["CategoryId"] as int?;
    bool hasFilter = !string.IsNullOrWhiteSpace(search) || selectedCat.HasValue;
    var products = Model?.ToList() ?? new List<Product>();
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="form-inline">
                <div class="input-group">
                    <input name="search" value="@search" class="form-control" placeholder="Поиск продуктов..." />
                    <select name="categoryId" class="form-select ms-2">
                        <option value="">Все категории</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(selectedCat == cat.Id ? "selected" : null)">@cat.Name</option>
                        }
                    </select>
                    <button class="btn btn-primary ms-2" type="submit">Поиск</button>
                </div>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Корзина</a>
            <a asp-controller="Users" asp-action="Login" class="btn btn-outline-primary ms-2">Войти</a>
        </div>
    </div>

    <h3>Популярные товары</h3>

    @* Если задан поиск/категория — показываем результаты; иначе — показываем ровно 3 карточки *@
    @if (hasFilter)
    {
        <div class="row">
            @if (!products.Any())
            {
                <div class="col-12">
                    <p class="text-muted">Товары не найдены.</p>
                </div>
            }
            else
            {
                @foreach (var p in products)
                {
                    <div class="col-sm-6 col-md-4 mb-4">
                        @await Html.PartialAsync("_ProductCard", p)
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="row">
            @{
                var featured = products.Take(3).ToList();
            }

            @if (!featured.Any())
            {
                <div class="col-12">
                    <p class="text-muted">Товары отсутствуют.</p>
                </div>
            }
            else
            {
                @foreach (var p in featured)
                {
                    <div class="col-sm-6 col-md-4 mb-4">
                        @await Html.PartialAsync("_ProductCard", p)
                    </div>
                }
            }
        </div>
    }

    <hr />
    <div class="row">
        <div class="col-md-4">
            <h5>Доставляем качественные продукты</h5>
            <p class="text-muted">Быстрое оформление, свежие продукты, удобные способы оплаты.</p>
        </div>
        <div class="col-md-4">
            <h5>Гарантия свежести</h5>
            <p class="text-muted">Возврат в случае несовпадения качества.</p>
        </div>
        <div class="col-md-4">
            <h5>Контакты</h5>
            <p class="text-muted">Телефон: +7 (900) 000-00-00</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site-products.js"></script>
}
