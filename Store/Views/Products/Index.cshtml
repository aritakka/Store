@model IEnumerable<Store.Models.Product>
@{
    ViewData["Title"] = "Товары";
}

<div class="container mt-4">
    <h2>Товары</h2>

    @* ✅ Кнопка "Добавить товар" сверху таблицы для Admin *@
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary mb-3">Добавить товар</a>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Количество</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Category?.Name</td>
                    <td>@p.Price</td>
                    <td>@p.Quantity</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-info btn-sm">Просмотр</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-danger btn-sm">Удалить</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>