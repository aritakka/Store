@model Store.Models.Product
@{
    ViewData["Title"] = "Редактировать товар";
    var categories = ViewBag.Categories as List<Store.Models.Category>;
}

<div class="container mt-4">
    <h2>Редактировать товар</h2>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label>Название</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Категория</label>
            <select asp-for="CategoryId" class="form-control">
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">
                        @c.Name
                    </option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label>Цена</label>
            <input asp-for="Price" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Количество</label>
            <input asp-for="Quantity" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Описание</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label>Фото</label>
            <input type="file" name="image" class="form-control" />
            <img src="@($"/images/products/{Model.Id}.jpg")" class="img-fluid mt-2" onerror="this.src='/images/placeholder.png'" />
        </div>
        <button type="submit" class="btn btn-success">Сохранить</button>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </form>
</div>