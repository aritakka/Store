@model Store.Models.Product

@{
    ViewData["Title"] = Model?.Name ?? "Детали товара";
}

<div class="container mt-4">
    <div class="row">

        <!-- 📷 Картинка -->
        <div class="col-md-5">
            <img src="~/images/products/@(Model?.Id).jpg"
                 class="img-fluid rounded"
                 alt="@Model?.Name"
                 onerror="this.src='/images/placeholder.png'">
            </div>

            <!-- 📄 Информация -->
            <div class="col-md-7">

                <h2>@Model?.Name</h2>

                <div class="text-muted mb-2">
                    Категория: @Model?.Category?.Name
                </div>

                <div class="h4 text-success mb-3">
                    @Model?.Price.ToString("C")
                </div>

                <h5>Описание</h5>
                <p class="text-muted">
                    @(string.IsNullOrWhiteSpace(Model?.Description)
                        ? "Описание отсутствует."
                        : Model.Description)
                </p>

                <h6>Информация</h6>
                <ul>
                    <li><strong>Количество:</strong> @Model?.Quantity</li>

                    @if (Model?.ProductSuppliers != null && Model.ProductSuppliers.Any())
                    {
                        var sup = Model.ProductSuppliers.FirstOrDefault()?.Supplier;
                        if (sup != null)
                        {
                            <li><strong>Поставщик:</strong> @sup.Name</li>
                        }
                    }
                </ul>

                <!-- 🔥 АДМИНКА -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="mt-3 p-3 border rounded bg-light">
                        <h5>Админ-панель</h5>

                        <a href="#" class="btn btn-warning">
                            Редактировать товар
                        </a>
                    </div>
                }

                <div class="mt-3">
                    <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-secondary">
                        Назад
                    </a>
                </div>

            </div>

        </div>
    </div>