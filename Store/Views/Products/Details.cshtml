@model Store.Models.Product

@{
    ViewData["Title"] = Model?.Name ?? "Детали товара";
}

<div class="container mt-4">
    <div class="row">

        <!-- 📷 Картинка -->
        <div class="col-md-5">
            <img src="~/images/products/@(Model?.Id).jpg"
                 class="img-fluid rounded"
                 onerror="this.src='/images/placeholder.png'">

                @if (User.IsInRole("Admin"))
                {
                    <form asp-action="UploadImage" asp-controller="Products" method="post" enctype="multipart/form-data" class="mt-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="file" name="file" class="form-control mb-2" />
                        <button type="submit" class="btn btn-dark">Загрузить фото</button>
                    </form>
                }
            </div>

            <!-- 📄 Информация -->
            <div class="col-md-7">

                <h2>@Model?.Name</h2>

                <div class="text-muted mb-2">
                    Категория: @Model?.Category?.Name
                </div>

                <!-- Цена -->
                <div class="mb-2">
                    <strong>Цена:</strong>
                    <span id="priceText">@Model?.Price</span>

                    @if (User.IsInRole("Admin"))
                    {
                        <input id="priceInput" type="number" value="@Model?.Price" class="form-control d-none" />
                    }
                </div>

                <!-- Количество -->
                <div class="mb-2">
                    <strong>Количество:</strong>
                    <span id="qtyText">@Model?.Quantity</span>

                    @if (User.IsInRole("Admin"))
                    {
                        <input id="qtyInput" type="number" value="@Model?.Quantity" class="form-control d-none" />
                    }
                </div>

                <!-- Описание -->
                <div class="mb-2">
                    <strong>Описание:</strong>
                    <p id="descText">@Model?.Description</p>

                    @if (User.IsInRole("Admin"))
                    {
                        <textarea id="descInput" class="form-control d-none">@Model?.Description</textarea>
                    }
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="mt-3">
                        <button id="editBtn" class="btn btn-warning">Редактировать</button>
                        <button id="saveBtn" class="btn btn-success d-none">Сохранить</button>
                    </div>
                }

                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                        Назад
                    </a>
                </div>

            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            const editBtn = document.getElementById("editBtn");
            const saveBtn = document.getElementById("saveBtn");

            if (editBtn) {
                editBtn.onclick = () => {
                    document.getElementById("priceText").classList.add("d-none");
                    document.getElementById("qtyText").classList.add("d-none");
                    document.getElementById("descText").classList.add("d-none");

                    document.getElementById("priceInput").classList.remove("d-none");
                    document.getElementById("qtyInput").classList.remove("d-none");
                    document.getElementById("descInput").classList.remove("d-none");

                    editBtn.classList.add("d-none");
                    saveBtn.classList.remove("d-none");
                };
            }

            if (saveBtn) {
                saveBtn.onclick = async () => {

                    const data = new FormData();

                    data.append("Id", "@Model.Id");
                    data.append("Price", document.getElementById("priceInput").value);
                    data.append("Quantity", document.getElementById("qtyInput").value);
                    data.append("Description", document.getElementById("descInput").value);

                    const response = await fetch("/Products/EditJson/@Model.Id", {
                        method: "POST",
                        body: data
                    });

                    const result = await response.json();

                    if (result.success) {
                        location.reload();
                    } else {
                        alert("Ошибка сохранения");
                    }
                };
            }
        </script>
    }